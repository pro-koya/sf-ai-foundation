{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf-ai-foundation.dev/schemas/release-doc.schema.json",
  "title": "SF-AI-Foundation Release Doc",
  "description": "Phase 4 リリース資材スキーマ。manual_step / release_doc を含む。",
  "type": "object",
  "required": [
    "version",
    "fromRef",
    "toRef",
    "createdAt",
    "changeSummaryIds",
    "targets",
    "manualSteps",
    "preChecks",
    "postChecks",
    "goNoGo",
    "rollbackDraft",
    "customerCommunication"
  ],
  "properties": {
    "version": { "$ref": "#/$defs/TrackedString" },
    "fromRef": { "$ref": "#/$defs/TrackedString" },
    "toRef": { "$ref": "#/$defs/TrackedString" },
    "createdAt": { "$ref": "#/$defs/TrackedString" },
    "changeSummaryIds": { "$ref": "#/$defs/TrackedStringArray" },
    "targets": { "$ref": "#/$defs/TrackedStringArray" },
    "manualSteps": { "type": "array", "items": { "$ref": "#/$defs/ManualStep" } },
    "preChecks": { "$ref": "#/$defs/TrackedStringArray" },
    "postChecks": { "$ref": "#/$defs/TrackedStringArray" },
    "goNoGo": {
      "type": "object",
      "required": ["verdict", "rationale"],
      "properties": {
        "verdict": { "$ref": "#/$defs/TrackedGoNoGoVerdict" },
        "rationale": { "$ref": "#/$defs/TrackedStringArray" }
      }
    },
    "rollbackDraft": { "$ref": "#/$defs/TrackedStringArray" },
    "customerCommunication": { "$ref": "#/$defs/TrackedString" }
  },
  "$defs": {
    "Source": { "type": "string", "enum": ["deterministic", "ai", "human"] },
    "TrackedString": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "string" },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "TrackedBoolean": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "boolean" },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "TrackedNumber": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "number" },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "TrackedStringArray": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "TrackedManualStepCategory": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "string", "enum": ["pre_release", "during_release", "post_release"] },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "TrackedGoNoGoVerdict": {
      "type": "object",
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "string", "enum": ["go", "no_go", "conditional"] },
        "source": { "$ref": "#/$defs/Source" },
        "promptHash": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" }
      }
    },
    "ManualStep": {
      "type": "object",
      "required": [
        "id",
        "title",
        "category",
        "relatedChange",
        "target",
        "procedure",
        "timing",
        "executorRole",
        "verification",
        "estimatedDurationMin",
        "reversible",
        "notes"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/TrackedString" },
        "title": { "$ref": "#/$defs/TrackedString" },
        "category": { "$ref": "#/$defs/TrackedManualStepCategory" },
        "relatedChange": { "$ref": "#/$defs/TrackedString" },
        "target": { "$ref": "#/$defs/TrackedString" },
        "procedure": { "$ref": "#/$defs/TrackedStringArray" },
        "timing": { "$ref": "#/$defs/TrackedString" },
        "executorRole": { "$ref": "#/$defs/TrackedString" },
        "verification": { "$ref": "#/$defs/TrackedString" },
        "estimatedDurationMin": { "$ref": "#/$defs/TrackedNumber" },
        "reversible": { "$ref": "#/$defs/TrackedBoolean" },
        "notes": { "$ref": "#/$defs/TrackedString" }
      }
    }
  }
}
